{
  "name": "0xmux",
  "version": "0.1.0",
  "private": true,
  "description": "Hacker-grade tmux session manager with web UI",
  "scripts": {
    "dev": "bash ./scripts/dev.sh",
    "dev:web": "cd web && bunx vite build --watch",
    "dev:api": "cd server && cargo watch -q -c -w src -x 'run -- --port 1235'",
    "build": "bun run build:web && bun run build:server",
    "build:web": "cd web && bun run build",
    "build:server": "cd server && cargo build --release --features embed-frontend",
    "start": "cd server && cargo run --release --features embed-frontend"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "concurrently": "^9.0.0"
  },
  "dependencies": {
    "canvas": "^3.2.1"
  }
}
